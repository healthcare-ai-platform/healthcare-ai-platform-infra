# =============================================================================
# Copy this file to your backend as .env and fill in real values for prod.
# All values below work out-of-the-box with docker-compose up.
# =============================================================================

# ── PostgreSQL (operational) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthcare

# ── Redshift local (warehouse) ───────────────────────────────────────────────
# Swap this URL for your real Redshift endpoint in staging/prod.
REDSHIFT_URL=postgresql+asyncpg://warehouse:warehouse@localhost:5433/warehouse

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
# boto3 picks up AWS_ENDPOINT_URL automatically when set.
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=healthcare-docs

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here
